okx:
  api_key: "your_okx_api_key"
  api_secret: "your_okx_api_secret"
  passphrase: "your_okx_passphrase"
  sandbox: true
  simulated_id: "1"
  simulated_trading: true
  default_type: "swap"
  timeout_ms: 10000

database:
  path: "data/market_adaptive.sqlite3"

runtime:
  timezone: "Asia/Shanghai"
  default_timeframe: "1h"
  default_ohlcv_limit: 200
  account_check_interval_seconds: 60
  risk_check_interval_seconds: 60
  fast_risk_check_interval_seconds: 1
  shutdown_cancel_open_orders: true
  start_grid_websocket_on_boot: true
  shutdown_join_timeout_seconds: 5.0
  account_initial_equity: 0.0

risk_control:
  daily_loss_cutoff_pct: 0.05
  max_margin_ratio: 0.60
  recovery_check_interval_seconds: 60
  position_sync_tolerance: 0.000001
  default_symbol_max_notional: 0
  symbol_notional_limits:
    BTC/USDT: 1500
    ETH/USDT: 1000
  cta_single_trade_equity_multiple: 1.5
  max_directional_leverage: 8.0
  grid_margin_ratio_warning: 0.45
  grid_deviation_reduce_ratio: 0.25
  grid_liquidation_warning_ratio: 0.10
  grid_reduction_step_pct: 0.25
  grid_reduction_cooldown_seconds: 300

sentiment:
  enabled: true
  symbol: "BTC/USDT"
  timeframe: "5m"
  lookback_limit: 1
  extreme_bullish_ratio: 2.5
  cta_buy_action: "block"  # 可选: block / halve

market_oracle:
  symbol: "BTC/USDT"
  polling_interval_seconds: 300
  higher_timeframe: "1h"
  lower_timeframe: "15m"
  prefer_closed_higher_timeframe_candles: true
  prefer_closed_lower_timeframe_candles: true
  lookback_limit: 200
  adx_length: 14
  bb_length: 20
  bb_std: 2.0
  trend_adx_threshold: 25
  sideways_adx_threshold: 20
  trend_di_gap_threshold: 8
  relaxed_trend_adx_buffer: 1.5
  relaxed_trend_di_gap_bonus: 1.0
  bb_width_contraction_tolerance_ratio: 0.03
  impulse_timeframe: "1m"
  prefer_closed_impulse_candles: false
  impulse_consecutive_bars: 3
  impulse_volume_window: 12
  impulse_volume_multiplier: 1.2

execution:
  td_mode: "isolated"
  cta_order_size: 0.01
  grid_order_size: 0.01

notification:
  discord:
    enabled: false
    channel_id: ""
    webhook_url: ""
    bot_token: ""
    username: "Market-Adaptive"

cta:
  symbol: "BTC/USDT"
  major_timeframe: "4h"
  swing_timeframe: "1h"
  execution_timeframe: "15m"
  prefer_closed_major_timeframe_candles: true
  prefer_closed_swing_timeframe_candles: true
  prefer_closed_execution_timeframe_candles: false
  # 兼容旧配置：execution_timeframe = lower_timeframe，swing_timeframe = higher_timeframe
  lower_timeframe: "15m"
  higher_timeframe: "1h"
  lookback_limit: 200
  supertrend_period: 10
  supertrend_multiplier: 3.0
  swing_rsi_period: 14
  swing_rsi_ready_threshold: 50.0
  dynamic_rsi_floor: 45.0
  rsi_rebound_lookback: 6
  rsi_oversold_threshold: 30.0
  rsi_rebound_confirmation_level: 35.0
  strong_bull_bias_score: 60.0
  weak_bull_bias_score: 0.8
  weak_bull_memory_score_bonus: 0.0
  dynamic_rsi_trend_score: 15.0
  dynamic_rsi_rebound_score: 15.0
  early_bullish_score_bonus: 10.0
  bullish_ready_score_threshold: 55.0
  weak_bias_fast_ema: 21
  weak_bias_slow_ema: 55
  kdj_length: 9
  kdj_k_smoothing: 3
  kdj_d_smoothing: 3
  execution_breakout_lookback: 3
  obv_signal_period: 8
  obv_signal_window: 8
  obv_signal_threshold_degrees: 30.0
  obv_slope_window: 8
  obv_slope_threshold_degrees: 30.0  # legacy field, no longer used for CTA entry gating
  obv_sma_period: 50
  obv_zscore_window: 100
  obv_zscore_threshold: 1.0
  atr_period: 14
  atr_trailing_multiplier: 2.5
  stop_loss_atr: 2.0
  risk_percent_per_trade: 0.02
  boosted_risk_percent_per_trade: 0.03
  first_take_profit_pct: 0.02
  first_take_profit_size: 0.50
  second_take_profit_pct: 0.05
  second_take_profit_size: 0.25
  minimum_expected_rr: 0.0
  relaxed_entry_minimum_expected_rr: 0.0
  starter_entry_minimum_expected_rr: 0.0
  early_entry_minimum_score: 70.0
  starter_frontrun_minimum_score: 80.0
  relaxed_entry_require_near_breakout: true
  starter_entry_require_near_breakout: true
  early_entry_direction_confirmation_bars: 2
  volume_profile_lookback_hours: 24
  volume_profile_bin_count: 24
  volume_profile_value_area_pct: 0.70
  order_flow_enabled: true
  order_flow_depth_levels: 20
  order_flow_confirmation_ratio: 1.5
  order_flow_high_conviction_ratio: 2.0
  order_flow_limit_buffer_bps: 3.0
  order_flow_max_slippage_bps: 12.0
  heartbeat_interval_seconds: 300.0
  near_miss_report_interval_seconds: 7200.0
  near_miss_report_max_samples: 5
  near_miss_report_min_samples: 2
  signal_profiler_summary_interval: 20
  signal_profiler_min_blocking_count: 2
  starter_frontrun_enabled: true
  starter_frontrun_fraction: 0.20
  starter_frontrun_breakout_buffer_ratio: 0.002
  bullish_memory_retest_breakout_buffer_ratio: 0.0026
  starter_frontrun_impulse_bars: 3
  starter_frontrun_volume_window: 12
  starter_frontrun_volume_multiplier: 1.15
  polling_interval_seconds: 60
  cta_assist_trim_ratio: 0.25
  # 兼容旧配置，留空即可
  timeframe: "15m"
  fast_ema: 7
  slow_ema: 21

grid:
  symbol: "BTC/USDT"
  equity_allocation_ratio: 0.40
  bollinger_timeframe: "1h"
  lookback_limit: 120
  bollinger_length: 20
  bollinger_std: 2.0
  levels: 8
  leverage: 3
  martingale_factor: 1.25
  layer_trigger_window_seconds: 300
  layer_trigger_limit: 3
  layer_cooldown_seconds: 300
  rebalance_exposure_threshold: 2.0
  max_rebalance_orders: 2
  polling_interval_seconds: 60
  price_band_ratio: 0.03
  liquidation_protection_ratio: 0.05
  use_dynamic_range: true
  atr_timeframe: "1h"
  atr_period: 14
  atr_multiplier: 2.5
  min_spacing_ratio: 0.007
  fee_rate: 0.001
  directional_skew_enabled: true
  directional_bias_threshold: 0.20
  sideways_neutral_bias_threshold: 0.12
  bearish_directional_bias_threshold: 0.30
  bullish_buy_levels: 6
  bullish_sell_levels: 2
  bullish_buy_spacing_ratio: 0.0045
  bullish_sell_spacing_ratio: 0.011
  bullish_center_shift_atr_ratio: 0.003
  bearish_buy_levels: 2
  bearish_sell_levels: 6
  bearish_buy_spacing_ratio: 0.011
  bearish_sell_spacing_ratio: 0.0045
  bearish_center_shift_atr_ratio: 0.003
  atr_regrid_change_ratio: 0.10
  regrid_trigger_atr_ratio: 0.30
  min_grid_lifetime_seconds: 300
  flash_crash_enabled: true
  flash_crash_timeframe: "1m"
  flash_crash_atr_multiplier: 1.5
  flash_crash_cooldown_seconds: 300
  hard_stop_buffer_ratio: 0.01
  max_directional_exposure_ratio: 0.50
  websocket_order_sync_enabled: true
  heavy_inventory_threshold: 0.60
  active_hedge_mode_enabled: false
  active_hedge_min_inventory_ratio: 0.45
  active_hedge_requires_cta_position: true
